        </mxCell>
        <mxCell id="c1" value="/upload &lt;file&gt;&#xa;上传面试稿或录音" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_input">
