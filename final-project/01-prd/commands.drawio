        <mxCell id="c4" value="/skip &lt;n&gt;&#xa;跳过第 n 题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_diag">
          <mxGeometry x="15" y="90" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="/compare &lt;n&gt;&#xa;对比第 n 题与高手答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_diag">
          <mxGeometry x="15" y="125" width="220" height="45" as="geometry" />
