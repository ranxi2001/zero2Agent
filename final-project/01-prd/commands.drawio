        <!-- Group: Input -->
        <mxCell id="grp_input" value="输入" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;collapsible=0;rounded=1;arcSize=8;" vertex="1" parent="1">
