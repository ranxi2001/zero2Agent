        <mxCell id="c7" value="/detail &lt;n&gt;&#xa;查看第 n 题详细诊断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_out">
