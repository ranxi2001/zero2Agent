        <mxCell id="c2" value="/mock [dimension]&#xa;开始模拟面试" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_input">
          <mxGeometry x="15" y="90" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="c10" value="/reset&#xa;清空当前会话" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_input">
          <mxGeometry x="15" y="125" width="220" height="45" as="geometry" />
        </mxCell>

        <!-- Group: Diagnosis -->
        <mxCell id="grp_diag" value="诊断" style="swimlane;startSize=25;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;collapsible=0;rounded=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="50" width="250" height="180" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="/diagnose&#xa;开始诊断当前上传内容" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="grp_diag">
          <mxGeometry x="15" y="35" width="220" height="45" as="geometry" />
